# Скопировать в .env и заполнить.

# === Telegram ===
# Токен от @BotFather: /newbot → имя → username → сохранить выданную строку
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# === LLM через openclaw-claude-proxy (опционально) ===
# Установка прокси: npm install -g openclaw-claude-proxy && openclaw-claude-proxy
# По умолчанию слушает http://localhost:3000. Эндпойнт OpenAI-совместимый: /v1
#
# Если эти переменные НЕ заданы — бот работает в rule-based режиме (без LLM).

# OPENAI_BASE_URL=http://localhost:3000/v1
# OPENAI_API_KEY=dummy-key-for-proxy
# LLM_MODEL=claude-sonnet-4-6

# === Хранилище истории чатов ===
# sqlite (default) — пишет в data/chat_history.db, доступно для веб-морды
# memory          — in-process, теряется при рестарте
# none            — не сохраняем вообще
# CHAT_HISTORY_BACKEND=sqlite
# CHAT_HISTORY_DB=data/chat_history.db

# === Веб-морда (если используется scripts/run_webapp.py) ===
# WEBAPP_HOST=127.0.0.1
# WEBAPP_PORT=8000
